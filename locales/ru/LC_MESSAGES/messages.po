#: main.py:33
msgid "Yangi CV/Rezyume yaratish"
msgstr "Создать новое резюме"

#: main.py:38
msgid "⏭ O‘tkazib yuborish"
msgstr "⏭ Пропустить"

#: main.py:91
msgid "Iltimos tilni tanlang: "
msgstr "Пожалуйста, выберите язык:"

#: main.py:105
msgid "Til o'zgartirildi."
msgstr "Язык был изменен."

#: main.py:111
msgid "Ism va Familiyangizni kiritng:"
msgstr "Введите ваше имя и фамилию:"

#: main.py:117
msgid "Endi manzilingizni kiriting (shahar, tuman):"
msgstr "Теперь введите свой адрес (город, район):"

#: main.py:124
msgid "Telefon raqamingizni yuboring:"
msgstr "Отправьте свой номер телефона:"

#: main.py:138
msgid ""
"❌ Telefon raqam noto‘g‘ri.\n"
"Masalan: +998901234567"
msgstr ""
"❌ Неверный номер телефона.\n"
"Пример: +998901234567"

#: main.py:142
msgid "Email yuboring:"
msgstr "Отправить вашу email:"

#: main.py:155
msgid ""
"❌ Email noto‘g‘ri.\n"
"Masalan: example@gmail.com"
msgstr ""
"❌ Неверный адрес электронной почты.\n"
"Пример: example@gmail.com"

#: main.py:159
msgid "Sohangizni kiriting:"
msgstr "Укажите свою профессию:"

#: main.py:167
msgid "🎓 Ta’lim tarixini kiriting. Qayerda o‘qigansiz?"
msgstr "🎓 Введите информацию о вашем образовании. Где вы учились?"

#: main.py:177
msgid "Qaysi yillarda o‘qigansiz(2020-2022)?"
msgstr "В какие годы вы учились (2020-2022)?"

#: main.py:191 main.py:286
msgid ""
"❌ Format noto‘g‘ri.\n"
"Masalan: 2021 - 2024"
msgstr ""
"❌ Неверный формат.\n"
"Например: 2021 - 2024"

#: main.py:198
msgid "Qaysi yo‘nalishda o‘qigansiz?"
msgstr "Какую специальность вы изучали?"

#: main.py:213 main.py:315
msgid "Ha"
msgstr "Да"

#: main.py:213 main.py:315
msgid "Yo‘q"
msgstr "Нет"

#: main.py:218
msgid "Yana ta’lim qo‘shasizmi?"
msgstr "Вы планируете расширить образовательную деятельность?"

#: main.py:224
msgid "Qayerda o‘qigansiz?"
msgstr "Где вы учились?"

#: main.py:227
msgid "Nimalarni bilasiz:"
msgstr "Что вы знаете:"

#: main.py:235
msgid "Portfolio/GitHub uchun link kiritng (ixtiyoriy):"
msgstr "Введите ссылку на ваше портфолио/GitHub (необязательно):"

#: main.py:241 main.py:248
msgid "Qaysi tillarni bilasiz:"
msgstr "Какие языки вы знаете?"

#: main.py:256
msgid "O'zingiz haqingizda ma'lumotlarni kiriting:"
msgstr "Введите информацию о себе:"

#: main.py:262
msgid "Qayerda ishlaganingizni kiriting:"
msgstr "Введите где вы работали:"

#: main.py:272
msgid "Qaysi yillarda ishladingiz?"
msgstr "В какие годы вы работали?"

#: main.py:293
msgid "Lavozimingiz?"
msgstr "Какова ваша позиция?"

#: main.py:301
msgid "Batafsil nima ish qildingiz?"
msgstr "Что именно вы сделали?"

#: main.py:320
msgid "Yana ish joyi qo‘shasizmi?"
msgstr "Вы добавите еще одну вакансию?"

#: main.py:326
msgid "Qayerda ishladingiz?"
msgstr "Где вы работали?"

#: main.py:346
msgid "Tayyorlanmoqda, iltimos kuting..."
msgstr "Идет подготовка, пожалуйста, подождите..."

#: main.py:351
msgid "Sizning professional CV-ingiz tayyor! ✨"
msgstr "Ваше профессиональное резюме готово! ✨"
